{
  "name": "vanilla-basic",
  "version": "1.0.0",
  "scripts": {
    "start": "sirv ./src public --cors --single --no-clear --port 8000",
    "start:app": "sirv ./src --cors --single --dev --port 4280",
    "start:api": "cd api && dotnet build && func start --port 7071",
    "start:azurite": "azurite --silent --location .azurite --debug .azurite\\debug.log",
    "swa": "swa start http://localhost:4280 --api-location ./api --run \"npm run start:app\"",
    "dev": "swa start http://localhost:4280 --api-location ./api --run \"npm run start:app\""
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.7",
    "azurite": "^3.35.0",
    "sirv-cli": "^3.0.1"
  }
}
