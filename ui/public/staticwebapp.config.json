{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/admin.html", "/djportal.html", "/notfound.html", "/events/*.html", "*.{css,js,jpg,png,gif,svg,ico,xml}", "/api/*"]
  },
  "routes": [
    {
      "route": "/djportal.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/create",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/update",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/delete",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/deleteall",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/deleteexpired",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/deletecache",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/deployment/rebuild",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/insights/searchterms",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/musicrequest/updatestatus",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/github"
    }
  ],
  "mimeTypes": {
    ".xml": "application/xml"
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/github"
    },
    "404": {
      "rewrite": "/notfound.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
      "content-security-policy": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self'; img-src 'self'; font-src 'self'; frame-src 'self'; frame-ancestors 'self'; upgrade-insecure-requests; form-action 'self'",
      "X-Frame-Options": "DENY",
      "X-XSS-Protection": "0",
      "Referrer-Policy":"strict-origin-when-cross-origin",
      "X-Content-Type-Options": "nosniff",
      "Strict-Transport-Security": "max-age=63072000"
  }
}
