{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/admin.html", "/djportal.html", "/notfound.html", "*.{css,js,jpg,png,gif,svg,ico}", "/api/*"]
  },
  "routes": [
    {
      "route": "/djportal.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/aad"
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    },
    "404": {
      "rewrite": "/notfound.html",
      "statusCode": 404
    }
  }
}
