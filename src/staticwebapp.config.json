{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/admin.html",
      "/djportal.html",
      "/notfound.html",
      "*.{css,js,jpg,png,gif,svg,ico}",
      "/api/*"
    ]
  },
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/github"
    },
    "404": {
      "rewrite": "/notfound.html",
      "statusCode": 404
    }
  }
}