{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/admin.html", "/djportal.html", "/notfound.html", "*.{css,js,jpg,png,gif,svg,ico}", "/api/*"]
  },
  "routes": [
    {
      "route": "/djportal.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/list",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET",
        "Access-Control-Allow-Headers": "Content-Type"
      }
    },
    {
      "route": "/api/events/create",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/update",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/delete",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/deleteall",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/deleteexpired",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/events/deletecache",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/insights/searchterms",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/musicrequest/updatestatus",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/github"
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/github"
    },
    "404": {
      "rewrite": "/notfound.html",
      "statusCode": 404
    }
  }
}
