{
  "navigationFallback": {
    "rewrite": "/notfound"
  },
  "routes": [
    {
      "route": "/djportal",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/admin",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/aad"
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad"
    },
    "404": {
      "rewrite": "/notfound",
      "statusCode": 404
    }
  }
}
